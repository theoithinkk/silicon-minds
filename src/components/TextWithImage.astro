---
/**
 * TextWithImage.astro
 *
 * A layout component that displays text content alongside an image. Perfect for
 * creating visually balanced content sections with optional image captions.
 *
 * ## Learning Notes
 * This component demonstrates several key Astro concepts:
 * - Component structure: Frontmatter (---) for logic, HTML template below
 * - Props interface: TypeScript definitions for type safety
 * - Markdown parsing: Converting Markdown strings to HTML at build time
 * - CSS-in-component: Scoped styles that only affect this component
 * - Responsive design: Mobile layout stacks content vertically
 *
 * ## Props
 *   - heading      (string)  – Optional section heading
 *   - body         (string)  – Body content; automatically converted from Markdown to HTML
 *   - imageSrc     (string)  – Image URL or path (required)
 *   - imageAlt     (string)  – Alt text for accessibility (required)
 *   - imageCaption (string)  – Optional caption below image; supports Markdown
 *   - reverse      (boolean) – If true, swaps layout to image-left / text-right
 *
 * ## Usage Example
 * ```astro
 * <TextWithImage
 *   heading="Why Astro?"
 *   body="Astro lets you **build faster** with less JavaScript."
 *   imageSrc="/astro-logo.png"
 *   imageAlt="Astro logo"
 *   imageCaption="*Source: Astro documentation*"
 *   reverse={false}
 * />
 * ```
 */

import { marked } from "marked";

// Define the shape of props this component accepts
// The '?' means these props are optional
interface Props {
  heading?: string;
  body: string;
  imageSrc: string;
  imageAlt: string;
  imageCaption?: string;
  reverse?: boolean;
}

// Extract props from Astro.props and set defaults
// reverse defaults to false if not provided
const {
  heading,
  body,
  imageSrc,
  imageAlt,
  imageCaption,
  reverse = false,
} = Astro.props;

// Convert Markdown strings to HTML at build time (not runtime)
// marked.parse() processes full block elements (supports **bold**, lists, etc.)
// marked.parseInline() processes inline elements only (for captions)
const bodyHtml = marked.parse(body);
const captionHtml = imageCaption ? marked.parseInline(imageCaption) : null;
---

<!-- The template section renders HTML. Note the special Astro directives below. -->
<section class:list={["twi", { "twi--reverse": reverse }]}>
  <!-- class:list is an Astro directive that conditionally applies classes.
       It applies "twi" always, and "twi--reverse" only if reverse is true. -->
  <!-- (twi == 't'ext 'w'ith 'i'mage) -->

  <!-- Text column -->
  <div class="twi__text">
    <!-- Conditionally render heading if it was provided as a prop -->
    {heading && <h2 class="twi__heading">{heading}</h2>}
    <!-- set:html is an Astro directive that inserts HTML safely.
         We use it here because bodyHtml contains HTML tags from Markdown parsing.
         For text content, just use {variable} instead of set:html. -->
    <div class="twi__body prose" set:html={bodyHtml} />
  </div>

  <!-- Image column -->
  <figure class="twi__figure">
    <!-- loading="lazy" defers image loading until it's near the viewport (performance!) -->
    <img class="twi__image" src={imageSrc} alt={imageAlt} loading="lazy" />
    <!-- Only render the caption if it was provided and is not empty -->
    {captionHtml && <figcaption class="twi__caption" set:html={captionHtml} />}
  </figure>
</section>

<style>
  /* -- Layout ------------------------------------------- */
  .twi {
    display: grid;
    grid-template-columns: 3fr 1fr;
    /* 3fr means text gets 3x the width of the image column.
       This CSS Grid approach is flexible and responsive. */
    gap: 2.5rem;
    align-items: center; /* Vertically center content within each column */
  }

  /* Reverse variant: image left, text right
     CSS trick using direction: rtl to reverse flex/grid order without changing DOM.
     We then reset direction: ltr on children to keep their content left-to-right. */
  .twi--reverse {
    direction: rtl;
  }
  .twi--reverse > * {
    direction: ltr;
  }

  /* -- Image column -------------------------------------- */
  .twi__figure {
    margin: 0; /* Reset default figure margins */
    display: flex;
    flex-direction: column;
    gap: 0.5rem; /* Small gap between image and caption */
  }

  .twi__image {
    width: 100%; /* Responsive: scales to container width */
    height: auto; /* Maintain aspect ratio */
    display: block; /* Remove inline spacing */
    border-radius: var(--twi-radius);
    /* CSS custom properties (--twi-radius) allow styling from parent pages.
       Fallback values can be set in :root or parent components. */
    object-fit: cover; /* Crop image to fill its container while maintaining aspect ratio */
  }

  .twi__caption {
    font-size: 0.8rem;
    color: var(--twi-caption-color);
    text-align: center;
  }
  .twi__caption :global(a) {
    /* :global() allows us to style any <a> elements inside caption.
       Without :global(), Astro's CSS scoping would prevent the style from applying. */
    color: var(--twi-prose-link);
  }

  /* -- Mobile breakpoint ------------------------------- */
  @media (max-width: 640px) {
    .twi,
    .twi--reverse {
      grid-template-columns: 1fr; /* Stack to single column on small screens */
      direction: ltr; /* Reset direction for mobile */
    }
    .twi__figure {
      order: 1; /* Image appears second (after text) */
    }
    .twi__text {
      order: 0; /* Text appears first */
    }
  }
</style>
